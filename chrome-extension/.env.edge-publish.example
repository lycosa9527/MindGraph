# Microsoft Edge Add-ons Publish API (v1.1)
# Partner Center → Microsoft Edge → Publish API → Create API credentials
# Copy to .env.edge-publish (gitignored) and source before publishing.

EDGE_ADDON_CLIENT_ID=your-client-id-guid
EDGE_ADDON_API_KEY=your-api-key
EDGE_ADDON_PRODUCT_ID=your-product-id-guid

# Optional overrides
# EDGE_ADDON_API_BASE=https://api.addons.microsoftedge.microsoft.com
# EDGE_ADDON_RETRY_LIMIT=60
# EDGE_ADDON_RETRY_SECONDS=5
# EDGE_ADDON_PUBLISH_NOTES=Short inline notes (or use --notes-file instead)
