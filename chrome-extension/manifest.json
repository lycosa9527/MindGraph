{
  "manifest_version": 3,
  "minimum_chrome_version": "109",
  "minimum_edge_version": "120",
  "name": "MindGraph — Web to mind map",
  "version": "0.4.21",
  "description": "Mind map PNG and document download for MindGraph — Chrome and Edge.",
  "default_locale": "en",
  "permissions": ["activeTab", "scripting", "storage", "downloads", "tabs", "contextMenus", "notifications", "offscreen"],
  "host_permissions": [
    "https://mg.mindspringedu.com/*",
    "https://test.mindspringedu.com/*",
    "http://localhost:9527/*",
    "http://127.0.0.1:9527/*",
    "*://*.smartedu.cn/*",
    "*://*.cbern.com.cn/*",
    "https://wkretype.bdimg.com/*",
    "https://*/*",
    "http://*/*",
    "file:///*"
  ],
  "action": {
    "default_title": "__MSG_browserActionTitle__",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "generate-mindmap": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "__MSG_commandGenerateDescription__"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.smartedu.cn/*", "*://smartedu.cn/*"],
      "js": ["doc-extract/smartedu/token-read-page.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["vendor/pdfjs/pdf.worker.min.js"],
      "matches": ["*://*/*"]
    }
  ]
}
