{
  "name": "mindgraph-frontend",
  "private": true,
  "version": "5.145.0",
  "type": "module",
  "engines": {
    "node": ">=26.0.0"
  },
  "scripts": {
    "sync-version": "node scripts/sync-version.ts",
    "build-prompt-registry": "cd .. && python scripts/build_prompt_language_registry.py",
    "dev": "vite",
    "dev:pwa": "VITE_PWA_DEV=1 vite",
    "generate-pwa-icons": "node scripts/generate-pwa-icons.mjs",
    "prebuild": "npm run build-prompt-registry && npm run sync-version && npm run generate-pwa-icons && npm run check:sidebar-quotes",
    "build": "node --max-old-space-size=4096 node_modules/vue-tsc/bin/vue-tsc.js --noEmit && node --max-old-space-size=4096 node_modules/vite/bin/vite.js build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{vue,ts,js,json,css,scss}\"",
    "format:check": "prettier --check \"src/**/*.{vue,ts,js,json,css,scss}\"",
    "check": "node --max-old-space-size=4096 node_modules/vue-tsc/bin/vue-tsc.js --noEmit && npm run lint && npm run format:check",
    "check:fix": "npm run fix && npm run check",
    "check:scripts": "node scripts/sync-version.ts && node scripts/check-i18n-keys.ts && npm run check:sidebar-quotes && npm run check:pwa-workbox && npm run check:pdf-worker",
    "check:dep0205": "node scripts/check-dep0205.mjs",
    "check:vueuse-pure": "node scripts/check-vueuse-pure-annotations.mjs",
    "postinstall": "patch-package && node scripts/ensure-cross-platform-native-deps.mjs",
    "i18n:check-keys": "node scripts/check-i18n-keys.ts",
    "i18n:check-picker-stubs": "node scripts/check-i18n-picker-stubs.ts",
    "i18n:materialize-from-en": "node scripts/materialize-locale-bundles-from-en.ts",
    "i18n:build-zhtw": "node scripts/build-zhtw-from-zh.ts",
    "i18n:translate-from-en": "node scripts/translate-ui-locales-from-en.ts",
    "i18n:check-prompts": "cd .. && python scripts/check_prompt_output_languages_sync.py",
    "i18n:check": "npm run i18n:check-keys && npm run i18n:check-prompts",
    "i18n:verify-keyboard": "node scripts/verify-keyboard-layout-map.ts",
    "audit:element-plus": "node scripts/audit-element-plus-usage.ts",
    "i18n:generate-lazy-loaders": "node scripts/generate-lazy-locale-loaders.js",
    "import:sidebar-quotes": "node scripts/import-sidebar-quotes/index.ts",
    "check:sidebar-quotes": "node scripts/check-sidebar-quotes-shipped.ts",
    "check:pwa-workbox": "node scripts/check-pwa-workbox.ts",
    "check:pdf-worker": "node scripts/check-pdf-worker-version.ts",
    "fix": "npm run lint:fix && npm run format",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@fontsource/noto-sans": "^5.2.10",
    "@fontsource/noto-sans-arabic": "^5.2.10",
    "@fontsource/noto-sans-armenian": "^5.2.8",
    "@fontsource/noto-sans-bengali": "^5.2.11",
    "@fontsource/noto-sans-devanagari": "^5.2.8",
    "@fontsource/noto-sans-ethiopic": "^5.2.7",
    "@fontsource/noto-sans-georgian": "^5.2.8",
    "@fontsource/noto-sans-gujarati": "^5.2.7",
    "@fontsource/noto-sans-gurmukhi": "^5.2.9",
    "@fontsource/noto-sans-hebrew": "^5.2.8",
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@fontsource/noto-sans-kannada": "^5.2.9",
    "@fontsource/noto-sans-khmer": "^5.2.8",
    "@fontsource/noto-sans-kr": "^5.2.9",
    "@fontsource/noto-sans-lao": "^5.2.8",
    "@fontsource/noto-sans-malayalam": "^5.2.8",
    "@fontsource/noto-sans-meetei-mayek": "^5.2.8",
    "@fontsource/noto-sans-myanmar": "^5.2.7",
    "@fontsource/noto-sans-ol-chiki": "^5.2.8",
    "@fontsource/noto-sans-oriya": "^5.2.9",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@fontsource/noto-sans-sinhala": "^5.2.10",
    "@fontsource/noto-sans-tamil": "^5.2.7",
    "@fontsource/noto-sans-tc": "^5.2.9",
    "@fontsource/noto-sans-telugu": "^5.2.8",
    "@fontsource/noto-sans-thai": "^5.2.8",
    "@fontsource/noto-serif-tibetan": "^5.2.8",
    "@lucide/vue": "^1.17.0",
    "@tanstack/vue-query": "^5.92.5",
    "@vscode/markdown-it-katex": "^1.1.2",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/core": "^1.48.1",
    "@vue-flow/minimap": "^1.5.4",
    "@vueuse/core": "^14.3.0",
    "chart.js": "^4.5.1",
    "docx-preview": "^0.3.7",
    "dompurify": "^3.2.4",
    "echarts": "^6.1.0",
    "element-plus": "^2.13.1",
    "fflate": "^0.8.2",
    "highlight.js": "^11.11.1",
    "html-to-image": "^1.11.11",
    "jspdf": "^4.2.0",
    "katex": "^0.17.0",
    "markdown-it": "^14.1.0",
    "mathlive": "^0.109.0",
    "mitt": "^3.0.1",
    "pdfjs-dist": "^4.10.38",
    "pinia": "^3.0.4",
    "simple-keyboard": "^3.8.125",
    "simple-keyboard-layouts": "^3.4.188",
    "vue": "^3.5.13",
    "vue-demi": "^0.14.10",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.1.0",
    "vue3-carousel-3d": "^1.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.19.19",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "eslint-plugin-vue": "^10.6.2",
    "globals": "^17.0.0",
    "google-translate-api-x": "^10.7.2",
    "jsdom": "^29.1.1",
    "opencc-js": "^1.3.1",
    "patch-package": "^8.0.1",
    "prettier": "^3.4.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.52.0",
    "undici": "^8.3.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.7",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.2.2"
  },
  "overrides": {
    "glob": "^13.0.6",
    "source-map-support": {
      "source-map": "0.6.1"
    },
    "workbox-build": {
      "source-map": "0.7.6"
    }
  },
  "allowScripts": {
    "core-js@3.49.0": true,
    "esbuild@0.27.3": true,
    "esbuild@0.28.0": true,
    "fsevents@2.3.3": true,
    "sharp@0.34.5": true,
    "vue-demi@0.14.10": true
  }
}
